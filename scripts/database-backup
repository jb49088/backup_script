#!/usr/bin/env bash

# ================================================================================
# =                               DATABASE-BACKUP                                =
# ================================================================================

# Collect databases from all systems and backup to restic
# - ArchLinux WSL: local databases
# - Debian Pi: remote databases via SSH

set -euo pipefail

# Setup temp directory
DB_DIR=~/temp/databases
mkdir -p "$DB_DIR"

echo "Collecting databases..."

# --- 1. ArchLinux WSL (local) ---
echo "  → WSL databases..."
if [ -d ~/databases ]; then
  cp -r ~/databases "$DB_DIR/wsl"
fi

# --- 2. Debian Pi (remote SSH) ---
echo "  → Pi databases..."
REMOTE_USER="master"
REMOTE_HOST="10.0.0.181"
REMOTE_DB_PATH="/home/master/databases"

scp -r "$REMOTE_USER@$REMOTE_HOST:$REMOTE_DB_PATH" "$DB_DIR/pi"

# --- 3. Backup to restic ---
echo "Backing up to restic..."
restic -r "$R1" backup "$DB_DIR" --tag databases
restic -r "$R2" backup "$DB_DIR" --tag databases

# --- 4. Prune old snapshots ---
echo "Pruning old snapshots..."
restic -r "$R1" forget --tag databases --keep-last 7 --prune
restic -r "$R2" forget --tag databases --keep-last 7 --prune

# --- 5. Clean up ---
rm -rf "$DB_DIR"

echo "Database backup completed successfully"
